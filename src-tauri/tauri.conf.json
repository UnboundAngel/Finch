{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "finch",
  "version": "0.1.0",
  "identifier": "com.finch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Finch",
        "width": 1000,
        "height": 750,
        "minWidth": 320,
        "minHeight": 400,
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/backgrounds/**",
          "$APPLOCALDATA/backgrounds/**",
          "$APPDATA/avatars/**",
          "$APPLOCALDATA/avatars/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
