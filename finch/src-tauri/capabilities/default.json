{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-close",
    "core:webview:allow-set-webview-position",
    "allow-eval-browser-js",
    "allow-reload-browser",
    "core:webview:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-is-maximized",
    "core:window:allow-available-monitors",
    "core:window:allow-set-resizable",
    "core:window:allow-start-dragging",
    "allow-get-provider-config",
    "allow-save-provider-config",
    "allow-list-anthropic-models",
    "allow-list-openai-models",
    "allow-list-gemini-models",
    "allow-list-local-models",
    "allow-send-message",
    "allow-stream-message",
    "allow-abort-generation",
    "allow-list-chats",
    "allow-load-chat",
    "allow-save-chat",
    "allow-delete-chat",
    "allow-eject-model",
    "allow-set-background-image",
    "allow-get-model-loaded-status",
    "allow-get-hardware-info",
    "allow-get-context-intelligence",
    "allow-start-recording",
    "allow-stop-recording",
    "allow-get-transcription-status",
    "allow-list-audio-devices",
    "allow-set-audio-device",
    "allow-download-voice-model",
    "allow-list-downloaded-voice-models",
    "allow-update-search-config",
    "dialog:default",
    "store:default"
  ]
}