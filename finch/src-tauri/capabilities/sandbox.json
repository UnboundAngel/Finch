{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "sandbox",
  "description": "Capability for the sandbox windows",
  "windows": [
    "sandbox-*"
  ],
  "permissions": [
    "core:default",
    "opener:allow-open-url",
    "allow-eval-browser-js",
    "allow-reload-browser",
    "core:webview:allow-eval-js",
    {
      "identifier": "core:webview:allow-navigate",
      "scope": {
        "allow": [
          "http://**",
          "https://**"
        ]
      }
    }
  ]
}