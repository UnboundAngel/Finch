{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "sandbox",
  "description": "Capability for the sandbox windows",
  "windows": [
    "sandbox-*"
  ],
  "permissions": [
    "core:default",
    "opener:allow-open-url",
    "allow-eval-browser-js",
    "allow-reload-browser",
    {
      "identifier": "core:webview:allow-create-webview-window",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}